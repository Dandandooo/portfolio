---
import "../styles/background-lines.css";
import "../styles/fonts.css";
import Navbar from "@/components/Navbar.astro";
import PhotoTile from "@/components/PhotoTile.astro";
import BaseHead from "@/components/BaseHead.astro";

type PhotoTileData = {
  title: string;
  size: "full" | "large" | "wide" | "tall" | "standard";
  image?: ImageMetadata;
  location?: string;
  description?: string;
};

import snowbird from "@/assets/images/snowbird_view.jpeg";

const photoTiles: PhotoTileData[] = [
  {
    title: "Portfolio Feature Strip",
    size: "full",
    // image: null
  },
  {
    title: "Golden Hour Street",
    size: "full",
    image: snowbird,
    location: "Snowbird Mountain Resort, UT"
  },
  { title: "Lake Reflection", size: "wide" },
  { title: "City Silhouette", size: "tall" },
  { title: "Morning Lines", size: "standard" },
  { title: "Trail in Fog", size: "wide" },
  { title: "Detail Study", size: "standard" },
  { title: "Pier at Dusk", size: "large" },
  { title: "Night Motion", size: "tall" },
];
---

<html lang="en">
  <BaseHead title="Daniel's Photography" favicon="/favicon-p.svg" />
  <body>
    <Navbar current="photography" />

    <main aria-label="Photography">
      <header>
        <p class="kicker">Frames, light, and stories through the lens</p>
        <h1>Photography</h1>
      </header>
      <section class="photo-grid" aria-label="Photography grid">
        {photoTiles.map((tile, index) => (
          <PhotoTile
            title={tile.title}
            size={tile.size}
            index={index + 1}
            image={tile.image}
            imageAlt={tile.title}
          />
        ))}
      </section>
    </main>
  </body>
</html>

<style>
  :global(:root) {
    --page-bg-color: #0c0806;
    --page-background:
      linear-gradient(180deg, #241812 0%, #31211a 46%, #15100c 100%),
      radial-gradient(100vw 60vh at 10% -10%, #86634f40, transparent 55%),
      radial-gradient(100vw 60vh at 85% -20%, #98705a38, transparent 60%);
    margin: 0;
    height: 100%;
    overflow: hidden;
    color: #f8fafc;
  }

  :global(body) {
    margin: 0;
    height: 100vh;
    overflow-y: auto;
    overflow-x: hidden;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior-y: none;
    color: #f8fafc;
    position: relative;
    isolation: isolate;
    font-family: "Lexend", "Segoe UI", sans-serif;
  }

  :global(:root) {
    --accent-cyan: #6a4d3f;
    --accent-lime: #b1967a;
    --accent-amber: #9a775d;
    --accent-rose: #8a6550;
    --accent-plum: #7a5c49;
    --accent-orange: #bf9978;
    --line-pattern-color: rgba(227, 205, 180, 0.1);
  }

  main {
    width: min(1120px, 92vw);
    margin: 1.25rem auto 2.5rem;
  }

  .kicker {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #c6ab92;
    font-size: 0.75rem;
  }

  h1 {
    margin: 0.15rem 0 1.2rem;
    font-family: "Rajdhani", sans-serif;
    letter-spacing: 0.04em;
    font-size: clamp(2rem, 4vw, 3.2rem);
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    grid-auto-rows: minmax(92px, auto);
    gap: 0.5rem;
    padding-bottom: 3rem;
  }

  @media (max-width: 980px) {
    .photo-grid {
      grid-template-columns: repeat(6, minmax(0, 1fr));
      grid-auto-rows: minmax(88px, auto);
    }
  }

  @media (max-width: 640px) {
    .photo-grid {
      grid-template-columns: 1fr;
      grid-auto-rows: auto;
      gap: 0.55rem;
    }
  }
</style>
