---
import Project from "@/components/project.astro";
import Navbar from "@/components/Navbar.astro";
import BaseHead from "@/components/BaseHead.astro";
import "@/styles/background-lines.css";
import "@/styles/fonts.css";

import { projects } from "@/data/projects.ts";
---

<html lang="en">
  <BaseHead title="Daniel's Projects" favicon="/favicon-g.svg" />
  <body>
    <Navbar current="projects" />

    <main>
      <header>
        <p class="kicker">Selected builds, research, and experiments</p>
        <h1>Projects</h1>
      </header>

      <section class="project-grid" aria-label="Projects">
        {
          projects.map((project, index) => (
            <Project {...project} index={index} />
          ))
        }
      </section>
    </main>
  </body>
</html>

<style>
  :global(:root) {
    --page-bg-color: #060c09;
    --page-background: linear-gradient(
        180deg,
        #0d1a13 0%,
        #0a1410 48%,
        #060c09 100%
      ),
      radial-gradient(100vw 60vh at 10% -10%, #2f8f6940, transparent 55%),
      radial-gradient(100vw 60vh at 85% -20%, #4b9b7240, transparent 60%);
    color: #f8fafc;
  }

  :global(body) {
    color: #f8fafc;
    position: relative;
    isolation: isolate;
    font-family: "Lexend", "Segoe UI", sans-serif;
  }

  :global(:root) {
    --accent-cyan: #38bdf8;
    --accent-lime: #a3e635;
    --accent-amber: #fbbf24;
    --accent-rose: #fb7185;
    --accent-plum: #c084fc;
    --accent-orange: #fb923c;
  }

  main {
    width: min(1120px, 92vw);
    margin: 1.25rem auto 2.5rem;
  }

  .kicker {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #86efac;
    font-size: 0.75rem;
  }

  h1 {
    margin: 0.15rem 0 1.2rem;
    font-family: "Rajdhani", sans-serif;
    letter-spacing: 0.04em;
    font-size: clamp(2rem, 4vw, 3.2rem);
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 1rem;
    align-items: start;
    padding-bottom: 5rem;
  }

  .project-grid :global(.info-card) {
    grid-column: span 4;
  }

  .project-grid :global(.info-card:nth-child(3n + 1)) {
    transform: translateY(0.4rem) rotate(-0.35deg);
  }

  .project-grid :global(.info-card:nth-child(3n + 2)) {
    transform: translateY(0.95rem) rotate(0.3deg);
  }

  .project-grid :global(.info-card:nth-child(3n)) {
    transform: translateY(0.8rem) rotate(-0.25deg);
  }

  .project-grid :global(.info-card:hover) {
    transform: translateY(-4px) rotate(-0.2deg);
  }

  @media (max-width: 1000px) {
    .project-grid :global(.info-card) {
      grid-column: span 6;
    }

    .project-grid :global(.info-card:nth-child(odd)) {
      transform: translateY(0.4rem);
    }

    .project-grid :global(.info-card:nth-child(even)) {
      transform: translateY(0);
    }
  }

  @media (max-width: 640px) {
    .project-grid {
      grid-template-columns: 1fr;
      gap: 0.55rem;
    }

    .project-grid :global(.info-card) {
      grid-column: auto;
      transform: none;
    }
  }
</style>
