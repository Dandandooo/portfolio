---
import "@/styles/background-lines.css";
import "@/styles/fonts.css";
import Navbar from "@/components/Navbar.astro";
import BaseHead from "@/components/BaseHead.astro";

import { Icon } from "astro-icon/components";

// https://icon-sets.iconify.design/catppuccin/page-2.html
const tech_stack: string[] = [
	"catppuccin:python",
	"catppuccin:zig",
	"catppuccin:rust-alt",
	"catppuccin:c",
	"catppuccin:cpp",
	"catppuccin:cuda",
	"catppuccin:javascript-react",
	"catppuccin:javascript",
	"catppuccin:typescript",
	"catppuccin:astro",
	"catppuccin:java",
	"catppuccin:ocaml",
	"catppuccin:lua",
	"catppuccin:latex",
	"catppuccin:docker",
	"catppuccin:git",
	"catppuccin:godot",
	"catppuccin:unity",
	"catppuccin:nix",
	"catppuccin:macos",
];

import photo from "@/assets/images/profile.jpeg";
import { Image } from "astro:assets";
---

<html lang="en">
	<BaseHead title="Daniel Philipov" favicon="/favicon-r.svg" />
	<body>
		<Navbar current="home" />
		<main>
			<header>
				<p class="kicker">Student, Researcher, Athlete</p>
				<h1>Daniel Philipov</h1>
			</header>
			<section class="profile-grid" aria-label="Profile layout">
				<div class="photo-frame" aria-label="Photo frame placeholder">
					<Image
						src={photo}
						alt="Daniel Philipov at sunset"
						class="profile-photo"
						loading="eager"
						fetchpriority="high"
					/>
				</div>
				<article class="bio-box">
					<h3>About Me</h3>
					<p>
						Hi, my name is Daniel Philipov! I am a Junior at UIUC
						studying Computer Science and Physics, and minoring in
						Astronomy.
					</p>
					<p>
						My hobbies include coding, competitive swimming, skiing,
						soccer, and playing video games with my friends and
						family.
					</p>
					<p>
						When it comes to coding, I'm driven by the beauty of
						code. I strive to achieve neatness, simplicity, and
						performance in everything I make, whether it be an AI
						algorithm, platformer game, or even this website.
					</p>
					<p>
						You can find me this summer at Google Sunnyvale, working
						on overhauling the GMail spam detection engine.
					</p>
					<h3>My Tech Stack</h3>
					{
						tech_stack.map((icon_name, _) => (
							<Icon
								name={icon_name}
								height="20pt"
								width="23pt"
								title={icon_name.split(":")[1]}
							/>
						))
					}
				</article>
			</section>
		</main>
	</body>
</html>

<style>
	:global(:root) {
		--page-bg-color: #0f0404;
		--page-background: linear-gradient(
				180deg,
				#350c0c 0%,
				#220707 48%,
				#0f0404 100%
			),
			radial-gradient(100vw 60vh at 10% -10%, #fb718550, transparent 55%),
			radial-gradient(100vw 60vh at 85% -20%, #ef444440, transparent 60%);
		--line-pattern-color: rgba(255, 235, 210, 0.16);
		margin: 0;
		height: 100%;
		overflow: hidden;
		color: #f8fafc;
	}

	:global(body) {
		margin: 0;
		height: 100vh;
		overflow: hidden;
		color: #f8fafc;
		position: relative;
		isolation: isolate;
		font-family: "Lexend", "Segoe UI", sans-serif;
	}

	:global(body::after) {
		content: "";
		position: fixed;
		inset: 0;
		pointer-events: none;
		background: rgba(7, 10, 17, 0.28);
		z-index: -1;
	}

	main {
		width: min(1120px, 92vw);
		height: calc(100vh - 5.5rem);
		margin: 1.25rem auto 2.5rem;
		display: grid;
		align-content: center;
		gap: 1rem;
	}

	.kicker {
		margin: 0;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: #fb7185;
		font-size: 0.75rem;
	}

	h1 {
		font-family: "Rajdhani", sans-serif;
		font-size: clamp(2.35rem, 6vw, 4.6rem);
		letter-spacing: 0.04em;
		margin: 0;
		color: #f8fafc;
	}

	@keyframes index-fade-in {
		0% {
			opacity: 0;
			transform: translateY(12px);
		}
		100% {
			opacity: 1;
			transform: translateY(0);
		}
	}

	header {
		opacity: 0;
		animation: index-fade-in 2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
	}

	.profile-grid {
		display: grid;
		grid-template-columns: minmax(220px, 38%) minmax(260px, 1fr);
		gap: clamp(1rem, 2.2vw, 1.5rem);
		align-items: stretch;
	}

	.photo-frame,
	.bio-box {
		border: 1px solid #ffffff26;
		border-radius: 16px;
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
	}

	.photo-frame {
		background: #090d16bd;
		min-height: clamp(300px, 46vh, 520px);
		position: relative;
		box-shadow: inset 0 0 0 1px rgba(252, 252, 250, 0.12);
		overflow: hidden;
		opacity: 0;
		animation: index-fade-in 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
		animation-delay: 0.25s;
	}

	:global(.photo-frame picture) {
		position: absolute;
		inset: 0;
		display: block;
	}

	:global(.photo-frame img.profile-photo) {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
		object-position: center center;
	}

	.photo-frame span {
		letter-spacing: 0.05em;
		color: #e2e8f0cc;
	}

	.bio-box {
		position: relative;
		background: radial-gradient(
				120% 120% at 0% 0%,
				rgba(251, 113, 133, 0.22),
				transparent 58%
			),
			linear-gradient(
				180deg,
				rgba(21, 8, 12, 0.95),
				rgba(21, 8, 12, 0.87)
			);
		border: 1px solid rgba(251, 113, 133, 0.32);
		box-shadow: 0 10px 35px rgba(0, 0, 0, 0.25);
		overflow: hidden;
		font-family: "Lexend", "Segoe UI", sans-serif;
		font-size: clamp(1.03rem, 1.45vw, 1.16rem);
		line-height: 1.6;
		color: #f8fafc;
		padding: clamp(1rem, 2vw, 1.35rem);
		opacity: 0;
		animation: index-fade-in 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
		animation-delay: 0.5s;
	}

	.bio-box::before {
		content: "";
		position: absolute;
		inset: 0;
		border-radius: inherit;
		pointer-events: none;
		border: 1px solid rgba(255, 255, 255, 0.12);
		mask: linear-gradient(#000, transparent 30%);
	}

	.bio-box h3 {
		margin: 0 0 0.75rem;
		font-family: "Rajdhani", sans-serif;
		font-size: 1.15rem;
		letter-spacing: 0.04em;
		color: #fda4af;
	}

	.bio-box p {
		margin: 0 0 0.9rem;
		color: #e7dbe1;
	}

	.bio-box p:last-child {
		margin-bottom: 0;
	}

	@media (max-width: 840px) {
		.profile-grid {
			grid-template-columns: 1fr;
		}

		.photo-frame {
			min-height: clamp(240px, 40vh, 340px);
		}
	}
</style>
