---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  title: string;
  size?: "standard" | "wide" | "tall" | "large" | "full";
  index?: number;
  description?: string;
  image?: ImageMetadata;
  imageAlt?: string;
  location?: string;
}

const {
  title,
  size = "standard",
  index = 1,
  description = "Replace this tile with a real photo asset.",
  image,
  imageAlt = title,
  location,
} = Astro.props;

const isFull = size === "full";
const isWide = size === "wide" || size === "large";
const imageWidths = isFull
  ? [1280, 1600, 2048, 2560, 3200]
  : isWide
    ? [768, 1024, 1280, 1600, 2048]
    : [640, 768, 960, 1280, 1600];
const imageSizes = isFull
  ? "(max-width: 640px) 100vw, 92vw"
  : isWide
    ? "(max-width: 640px) 100vw, (max-width: 980px) 50vw, 66vw"
    : "(max-width: 640px) 100vw, (max-width: 980px) 50vw, 33vw";
---

<article class:list={["photo-tile", `tile-${size}`]}>
  {image ? (
    <Image
      class:list={["tile-image", { "tile-image-full": isFull }]}
      src={image}
      alt={imageAlt}
      loading="lazy"
      widths={imageWidths}
      sizes={imageSizes}
      quality={90}
    />
  ) : (
    <div class="tile-placeholder" aria-hidden="true">
      <span>{String(index).padStart(2, "0")}</span>
    </div>
  )}
  <h2>{title}</h2>
  <p>{description}</p>
  {location && <div class="location-chip">{location}</div>}
</article>

<style>
  .photo-tile {
    position: relative;
    grid-column: span 4;
    grid-row: span 3;
    border: 1px solid #fff2;
    border-radius: 14px;
    background: linear-gradient(160deg, #2c1f18cc, #1a120dcc);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    box-shadow: inset 0 0 0 1px #ffffff12;
    overflow: hidden;
  }

  .photo-tile.tile-standard {
    grid-row: span 3;
  }

  .photo-tile.tile-wide {
    grid-column: span 8;
    grid-row: span 3;
  }

  .photo-tile.tile-tall {
    grid-row: span 4;
  }

  .photo-tile.tile-large {
    grid-column: span 8;
    grid-row: span 4;
  }

  .photo-tile.tile-full {
    grid-column: 1 / -1;
    grid-row: span 1;
  }

  .tile-placeholder {
    height: calc(100% - 3.3rem);
    background:
      linear-gradient(130deg, #c9a88922, #0000 55%),
      linear-gradient(180deg, #201510 0%, #120d0a 100%);
    border-bottom: 1px solid #ffffff1a;
    display: grid;
    place-items: center;
  }

  :global(.tile-image) {
    width: 100%;
    height: calc(100% - 3.3rem);
    display: block;
    object-fit: cover;
    object-position: center;
    border-bottom: 1px solid #ffffff1a;
  }

  :global(.tile-image.tile-image-full) {
    height: auto;
  }

  .tile-placeholder span {
    font-family: "Rajdhani", sans-serif;
    font-size: clamp(1.4rem, 2.2vw, 2rem);
    letter-spacing: 0.12em;
    color: #e0c6aeaa;
  }

  .photo-tile h2 {
    margin: 0.4rem 0.65rem 0.15rem;
    font-size: 0.95rem;
    letter-spacing: 0.03em;
    font-family: "Rajdhani", sans-serif;
    color: #f3e8db;
  }

  .photo-tile p {
    margin: 0 0.65rem;
    font-size: 0.74rem;
    color: #d9c2accc;
    padding-right: 7.5rem;
  }

  .location-chip {
    position: absolute;
    right: 0.55rem;
    bottom: 0.45rem;
    font-size: 0.78rem;
    letter-spacing: 0.03em;
    color: #f0e3d5;
    border: 1px solid #d7b89866;
    border-radius: 999px;
    background: #d7b89824;
    padding: 0.14rem 0.5rem;
    white-space: nowrap;
  }

  @media (max-width: 980px) {
    .photo-tile,
    .photo-tile.tile-wide,
    .photo-tile.tile-large {
      grid-column: span 3;
    }

    .photo-tile.tile-full {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 640px) {
    .photo-tile,
    .photo-tile.tile-standard,
    .photo-tile.tile-wide,
    .photo-tile.tile-tall,
    .photo-tile.tile-large,
    .photo-tile.tile-full {
      grid-column: auto;
      grid-row: auto;
      min-height: 260px;
    }
  }
</style>
