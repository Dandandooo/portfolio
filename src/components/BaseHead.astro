---
interface Props {
	title: string;
	favicon: string;
}

const { title, favicon } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<head>
	<meta charset="utf-8" />
	<link rel="icon" type="image/svg+xml" href={`${base}${favicon}`} />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<meta name="generator" content={Astro.generator} />
	<title>{title}</title>

	<!-- Preload custom fonts to eliminate FOUT/FOIT -->
	<link rel="preload" href={`${base}/fonts/Rajdhani-Bold.ttf`} as="font" type="font/ttf" crossorigin />
	<link rel="preload" href={`${base}/fonts/Lexend-VariableFont_wght.ttf`} as="font" type="font/ttf" crossorigin />
</head>
